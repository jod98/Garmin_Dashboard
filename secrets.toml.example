# Copy this file to .streamlit/secrets.toml for LOCAL testing.
# NEVER commit the real secrets.toml to GitHub.
# On Streamlit Community Cloud, paste these same keys into
# App settings -> Secrets (do not upload this file there).

# --- Used by the "This Week" dashboard page ---
GARMIN_EMAIL = "your_garmin_login_email@example.com"
GARMIN_PASSWORD = "your_garmin_password"

# --- Used by "Current Plan" and "Weekly Check-In" (AI coach pages) ---
DATABASE_URL = "postgresql://postgres.abc...:yourpassword@aws-0-...pooler.supabase.com:5432/postgres"
ANTHROPIC_API_KEY = "sk-ant-..."
